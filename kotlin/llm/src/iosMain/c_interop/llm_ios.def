# Updated: message-array API (roles/contents/count), no on_complete callback
headers = llm_ios.h
headerFilter = llm_ios.h
compilerOpts = -I$PROJECT_DIR/../third_party/llama.cpp/include \
               -I$PROJECT_DIR/../third_party/llama.cpp \
               -I$PROJECT_DIR/src/iosMain/c_interop/include
staticLibraries = libllm_merged.a
linkerOpts = -framework Accelerate -framework Metal -framework MetalKit -lc++ -ObjC
package = dev.deviceai.llm.native
