---
# DeviceAI .clang-tidy configuration
# Run locally: clang-tidy -p build/compile_commands.json <file>
# Generate compile_commands.json: cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON ...

Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-macro-parentheses,
  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-avoid-c-arrays,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-braces-around-statements,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-pro-type-reinterpret-cast

WarningsAsErrors: >
  bugprone-use-after-move,
  bugprone-dangling-handle,
  bugprone-infinite-loop,
  performance-move-const-arg,
  readability-redundant-smartptr-get

HeaderFilterRegex: '(kotlin/speech|kotlin/llm)/src/.*\.(h|hpp)$'

CheckOptions:
  - key: readability-function-cognitive-complexity.Threshold
    value: '25'
  - key: modernize-use-default-member-init.UseAssignment
    value: '1'
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: '1'
  - key: cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
    value: '1'
